# Database
POSTGRES_DB=dcc_one_shot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Used when Next.js runs on your workstation. Docker Compose constructs its own
# connection string with the "db" hostname from the POSTGRES_* values above.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dcc_one_shot

# Traefik — domain Traefik routes to this app (no https://)
TRAEFIK_HOST=dcc.yourdomain.com
# LAN_CIDR — only set in dev; restricts access to your local network
LAN_CIDR=192.168.1.0/24

# Auth (Better Auth) — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-generated-secret
# Use the public HTTPS origin in deployed environments.
BETTER_AUTH_URL=http://localhost:3000
