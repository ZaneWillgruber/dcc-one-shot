# Database
POSTGRES_DB=dcc_one_shot
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Constructed from the above — used by the app
DATABASE_URL=postgresql://postgres:changeme@db:5432/dcc_one_shot

# Traefik — domain Traefik routes to this app (no https://)
TRAEFIK_HOST=dcc.yourdomain.com
# LAN_CIDR — only set in dev; restricts access to your local network
LAN_CIDR=192.168.1.0/24

# Auth (Better Auth) — fill in when auth is added
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=https://dcc.yourdomain.com
